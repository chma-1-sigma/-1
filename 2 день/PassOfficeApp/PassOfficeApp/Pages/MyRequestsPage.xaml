<Page x:Class="PassOfficeApp.Pages.MyRequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои заявки" Background="#F0F4F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20">
            <TextBlock Text="📋 Мои заявки на посещение" FontSize="22" FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="0">
            <DataGrid x:Name="requestsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" BorderThickness="0" RowHeight="45"
                      AlternatingRowBackground="#F8F9FA" FontSize="13">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding RequestType}" Width="80"/>
                    <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="180"/>
                    <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Дата подачи" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="Причина отказа" Binding="{Binding RejectionReason}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock x:Name="emptyText" Grid.Row="1" Text="📭 У вас пока нет заявок" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" 
                   Foreground="#7F8C8D" Visibility="Collapsed"/>
    </Grid>
</Page>