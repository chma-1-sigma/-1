<Page x:Class="PassOfficeApp.Pages.PersonalRequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личное посещение" Background="#F0F4F8">

    <ScrollViewer>
        <StackPanel Margin="20">
            <TextBlock Text="📝 Оформление заявки на личное посещение" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Информация для пропуска -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📅 Информация для пропуска" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Срок действия:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <DatePicker x:Name="startDatePicker" Grid.Column="1" Width="180" Height="35"/>
                        <TextBlock Text="по" Grid.Column="2" VerticalAlignment="Center" Margin="15,0,15,0"/>
                        <DatePicker x:Name="endDatePicker" Grid.Column="3" Width="180" Height="35"/>
                    </Grid>

                    <TextBlock Text="Цель посещения:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="purposeCombo" Height="35" DisplayMemberPath="purpose_name" SelectedValuePath="id"/>
                </StackPanel>
            </Border>

            <!-- Принимающая сторона -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="👥 Принимающая сторона" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Подразделение:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="departmentCombo" Height="35" 
                              DisplayMemberPath="name" SelectedValuePath="id" 
                              SelectionChanged="DepartmentCombo_SelectionChanged" Margin="0,0,0,10"/>

                    <TextBlock Text="Сотрудник:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="employeeCombo" Height="35" 
                              DisplayMemberPath="full_name" SelectedValuePath="id" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- Информация о посетителе -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="👤 Информация о посетителе" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Фамилия:*" Margin="0,0,0,5"/>
                            <TextBox x:Name="lastNameBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Имя:*" Margin="0,0,0,5"/>
                            <TextBox x:Name="firstNameBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Отчество:" Margin="0,0,0,5"/>
                            <TextBox x:Name="middleNameBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Телефон:" Margin="0,0,0,5"/>
                            <TextBox x:Name="phoneBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0" Text="+7 "/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Email:*" Margin="0,0,0,5"/>
                            <TextBox x:Name="emailBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Организация:" Margin="0,0,0,5"/>
                            <TextBox x:Name="organizationBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Дата рождения:*" Margin="0,0,0,5"/>
                            <DatePicker x:Name="birthDatePicker" Height="35"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Примечание:*" Margin="0,0,0,5"/>
                    <TextBox x:Name="commentBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                             BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,5"/>
                </StackPanel>
            </Border>

            <!-- Паспортные данные -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="🪪 Паспортные данные" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Серия паспорта:* (4 цифры)" Margin="0,0,0,5"/>
                            <TextBox x:Name="passportSeriesBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0" MaxLength="4"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Номер паспорта:* (6 цифр)" Margin="0,0,0,5"/>
                            <TextBox x:Name="passportNumberBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0" MaxLength="6"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Прикрепляемые документы -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📎 Прикрепляемые документы" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Фотография (jpg, 3×4, до 4 Мб):" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                        <TextBox x:Name="photoPathBox" Width="300" Height="35" IsReadOnly="True" 
                                 BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        <Button x:Name="selectPhotoButton" Content="Выбрать фото" Click="SelectPhoto_Click" 
                                Background="#3498DB" Foreground="White" Height="35" Padding="15,0" Margin="10,0,0,0" Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock Text="Скан паспорта (pdf):*" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox x:Name="scanPathBox" Width="300" Height="35" IsReadOnly="True" 
                                 BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        <Button x:Name="selectScanButton" Content="Выбрать PDF" Click="SelectScan_Click" 
                                Background="#3498DB" Foreground="White" Height="35" Padding="15,0" Margin="10,0,0,0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,30">
                <Button x:Name="submitButton" Content="✅ Оформить заявку" Click="SubmitButton_Click" 
                        Background="#27AE60" Foreground="White" Height="45" Width="200" FontSize="14" Cursor="Hand" Margin="0,0,10,0"/>
                <Button x:Name="clearButton" Content="🗑️ Очистить форму" Click="ClearButton_Click" 
                        Background="#E74C3C" Foreground="White" Height="45" Width="200" FontSize="14" Cursor="Hand"/>
            </StackPanel>

            <TextBlock x:Name="errorText" Foreground="#E74C3C" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,10,0,20" FontSize="12"/>
        </StackPanel>
    </ScrollViewer>
</Page>