<Window x:Class="HranitelPro.Admin.AddToBlacklistDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление в черный список" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F4F8">

    <Border Background="White" CornerRadius="12" Margin="10" Padding="20">
        <StackPanel>
            <TextBlock Text="Добавление в черный список" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Фамилия:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtLastName" Height="35" Margin="0,5,0,10" IsReadOnly="True" Background="#F0F4F8"/>

            <TextBlock Text="Имя:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtFirstName" Height="35" Margin="0,5,0,10" IsReadOnly="True" Background="#F0F4F8"/>

            <TextBlock Text="Отчество:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtMiddleName" Height="35" Margin="0,5,0,10" IsReadOnly="True" Background="#F0F4F8"/>

            <TextBlock Text="Паспорт:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtPassport" Height="35" Margin="0,5,0,10" IsReadOnly="True" Background="#F0F4F8"/>

            <TextBlock Text="Причина добавления:*" FontWeight="SemiBold"/>
            <TextBox x:Name="txtReason" Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                     Margin="0,5,0,20" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnAdd" Content="Добавить" Click="AddButton_Click" 
                        Background="#27AE60" Foreground="White" Height="40" Width="120" Cursor="Hand" Margin="0,0,10,0"/>
                <Button x:Name="btnCancel" Content="Отмена" Click="CancelButton_Click" 
                        Background="#95A5A6" Foreground="White" Height="40" Width="120" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>