<Window x:Class="HranitelPro.Admin.DepartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО - Подразделение" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E3A5F">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="ХранительПРО" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" | Подразделение" FontSize="14" Foreground="#B0C4DE" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
                <Border Background="#2E5A88" CornerRadius="20" Padding="12,5" Margin="30,0,0,0">
                    <TextBlock x:Name="userNameText" Foreground="White" FontSize="12"/>
                </Border>
                <Button x:Name="logoutButton" Content="Выйти" Click="LogoutButton_Click" 
                        Background="#C0392B" Foreground="White" Height="32" Margin="15,0,0,0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="20,15,20,10" Padding="15">
            <StackPanel>
                <TextBlock Text="Фильтрация заявок" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Дата" Margin="0,0,0,5"/>
                        <DatePicker x:Name="filterDatePicker" Width="150" Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Тип" Margin="0,0,0,5"/>
                        <ComboBox x:Name="filterTypeCombo" Height="35">
                            <ComboBoxItem Content="Все" IsSelected="True"/>
                            <ComboBoxItem Content="Личная"/>
                            <ComboBoxItem Content="Групповая"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="2" Content="Найти" Click="ApplyFilter_Click" 
                            Background="#3498DB" Foreground="White" Height="35" Padding="15,0" Cursor="Hand" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Margin="20,0,20,20">
            <DataGrid x:Name="requestsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" BorderThickness="0" RowHeight="45" 
                      AlternatingRowBackground="#F8F9FA" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding request_id}" Width="60"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding request_type}" Width="80"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding full_name}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding visitor_email}" Width="180"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding phone}" Width="120"/>
                    <DataGridTextColumn Header="Дата посещения" Binding="{Binding start_date, StringFormat=dd.MM.yyyy}" Width="120"/>
                    <DataGridTextColumn Header="Время прибытия" Binding="{Binding VisitStartTimeStr}" Width="100"/>
                    <DataGridTextColumn Header="Время убытия" Binding="{Binding VisitEndTimeStr}" Width="100"/>
                    <DataGridTemplateColumn Header="Действие" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Прибытие" Click="SetArrival_Click" Tag="{Binding}" 
                                            Background="#27AE60" Foreground="White" Width="70" Height="30" Margin="0,0,5,0"/>
                                    <Button Content="ЧС" Click="AddToBlacklist_Click" Tag="{Binding}" 
                                            Background="#E74C3C" Foreground="White" Width="70" Height="30"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Background="#1E3A5F">
            <TextBlock Text="© 2024 ХранительПРО" Foreground="#7F8C8D" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>