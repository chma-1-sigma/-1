<Window x:Class="HranitelPro.Admin.SelectMemberDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор посетителя" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F4F8">

    <Border Background="White" CornerRadius="12" Margin="10" Padding="20">
        <StackPanel>
            <TextBlock Text="Выберите посетителя для добавления в черный список" 
                       FontSize="16" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>

            <ListBox x:Name="membersList" Height="250" Margin="0,0,0,20" 
                     DisplayMemberPath="DisplayName" SelectionMode="Single"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSelect" Content="Выбрать" Click="SelectButton_Click" 
                        Background="#27AE60" Foreground="White" Height="40" Width="120" Cursor="Hand" Margin="0,0,10,0"/>
                <Button x:Name="btnCancel" Content="Отмена" Click="CancelButton_Click" 
                        Background="#95A5A6" Foreground="White" Height="40" Width="120" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>