<Window x:Class="PassOfficeApp.Pages.AddVisitorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Добавление посетителя" Height="550" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F4F8"
        Icon="../Images/icon.png">

    <Border Background="White" CornerRadius="12" Margin="10">
        <StackPanel Margin="20">
            <TextBlock Text="➕ Добавление посетителя" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Фамилия:*"/>
            <TextBox x:Name="txtLastName" Height="35" Margin="0,5,0,10"/>
            <TextBlock Text="Имя:*"/>
            <TextBox x:Name="txtFirstName" Height="35" Margin="0,5,0,10"/>
            <TextBlock Text="Отчество:"/>
            <TextBox x:Name="txtMiddleName" Height="35" Margin="0,5,0,10"/>
            <TextBlock Text="Телефон:"/>
            <TextBox x:Name="txtPhone" Height="35" Text="+7 " Margin="0,5,0,10"/>
            <TextBlock Text="Email:*"/>
            <TextBox x:Name="txtEmail" Height="35" Margin="0,5,0,10"/>
            <TextBlock Text="Дата рождения:*"/>
            <DatePicker x:Name="dpBirthDate" Height="35" Margin="0,5,0,10"/>
            <TextBlock Text="Серия паспорта:* (4 цифры)"/>
            <TextBox x:Name="txtPassportSeries" Height="35" MaxLength="4" Margin="0,5,0,10"/>
            <TextBlock Text="Номер паспорта:* (6 цифр)"/>
            <TextBox x:Name="txtPassportNumber" Height="35" MaxLength="6" Margin="0,5,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="saveButton" Content="✅ Добавить" Click="SaveButton_Click" Background="#27AE60" Foreground="White" Height="40" Width="120" Cursor="Hand" Margin="0,0,10,0"/>
                <Button x:Name="cancelButton" Content="❌ Отмена" Click="CancelButton_Click" Background="#95A5A6" Foreground="White" Height="40" Width="120" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>