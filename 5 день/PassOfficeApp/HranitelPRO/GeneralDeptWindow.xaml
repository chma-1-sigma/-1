<Window x:Class="HranitelPRO.GeneralDeptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="ХранительПРО - Отдел кадров" Height="750" Width="1300"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#3498DB"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#1E3A5F">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="🛡️ ХранительПРО" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" | Отдел кадров" FontSize="14" Foreground="#B0C4DE" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
                <Border Background="#2E5A88" CornerRadius="20" Padding="12,5" Margin="30,0,0,0">
                    <TextBlock x:Name="userNameText" Foreground="White" FontSize="12"/>
                </Border>
                <Button x:Name="logoutButton" Content="Выйти" Click="LogoutButton_Click" Background="#C0392B" Foreground="White" Height="32" Margin="15,0,0,0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Вкладки -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="20,15,20,10" Padding="15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Button x:Name="btnRequests" Content="📋 Заявки" Click="ShowRequests_Click" Style="{StaticResource TabButton}" Background="#3498DB" Margin="0,0,10,0"/>
                    <Button x:Name="btnReports" Content="📊 Отчеты" Click="ShowReports_Click" Style="{StaticResource TabButton}" Background="#95A5A6" Margin="0,0,10,0"/>
                    <Button x:Name="btnCurrentVisitors" Content="👥 Текущие посетители" Click="ShowCurrentVisitors_Click" Style="{StaticResource TabButton}" Background="#95A5A6"/>
                </StackPanel>

                <!-- Панель заявок -->
                <StackPanel x:Name="panelRequests" Visibility="Visible">
                    <TextBlock Text="Фильтрация заявок" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Тип" Margin="0,0,0,5"/>
                            <ComboBox x:Name="filterTypeCombo" Height="35">
                                <ComboBoxItem Content="Все" IsSelected="True"/>
                                <ComboBoxItem Content="Личная"/>
                                <ComboBoxItem Content="Групповая"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Подразделение" Margin="0,0,0,5"/>
                            <ComboBox x:Name="filterDepartmentCombo" Height="35" DisplayMemberPath="name" SelectedValuePath="id"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="Статус" Margin="0,0,0,5"/>
                            <ComboBox x:Name="filterStatusCombo" Height="35">
                                <ComboBoxItem Content="Все" IsSelected="True"/>
                                <ComboBoxItem Content="проверка"/>
                                <ComboBoxItem Content="одобрена"/>
                                <ComboBoxItem Content="не одобрена"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                            <TextBlock Text="Поиск" Margin="0,0,0,5"/>
                            <TextBox x:Name="searchBox" Height="35" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
                        </StackPanel>

                        <Button Grid.Column="4" Content="Найти" Click="ApplyFilter_Click" Style="{StaticResource FilterButton}" VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>

                <!-- Панель отчетов -->
                <StackPanel x:Name="panelReports" Visibility="Collapsed">
                    <TextBlock Text="Отчеты по посещениям" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Border Background="#F0F4F8" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Параметры отчета" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Период" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="reportPeriodCombo" Height="35" SelectedIndex="0">
                                        <ComboBoxItem Content="День"/>
                                        <ComboBoxItem Content="Месяц"/>
                                        <ComboBoxItem Content="Год"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Дата" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="reportDatePicker" Height="35"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                    <TextBlock Text="Группировка" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="reportGroupCombo" Height="35">
                                        <ComboBoxItem Content="По подразделениям" IsSelected="True"/>
                                        <ComboBoxItem Content="По типам"/>
                                    </ComboBox>
                                </StackPanel>

                                <Button Grid.Column="3" Content="Сформировать отчет" Click="GenerateReport_Click" Background="#27AE60" Foreground="White" Height="35" Padding="15,0" Cursor="Hand" VerticalAlignment="Bottom"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Таблица отчета -->
                    <Border Background="White" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Результат" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <DataGrid x:Name="reportGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" RowHeight="35" AlternatingRowBackground="#F8F9FA" FontSize="13" MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Подразделение" Binding="{Binding Department}" Width="200"/>
                                    <DataGridTextColumn Header="Количество посещений" Binding="{Binding Count}" Width="150"/>
                                    <DataGridTextColumn Header="Процент" Binding="{Binding Percentage, StringFormat={}{0:F1}%}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Панель текущих посетителей -->
                <StackPanel x:Name="panelCurrentVisitors" Visibility="Collapsed">
                    <TextBlock Text="Текущие посетители на территории" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Button x:Name="btnRefreshVisitors" Content="Обновить" Click="RefreshCurrentVisitors_Click" Background="#3498DB" Foreground="White" Height="35" Width="120" Cursor="Hand" Margin="0,0,0,10"/>

                    <Border Background="White" CornerRadius="8" Padding="15">
                        <DataGrid x:Name="currentVisitorsGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" RowHeight="40" AlternatingRowBackground="#F8F9FA" FontSize="13">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Подразделение" Binding="{Binding Department}" Width="200"/>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding RequestType}" Width="100"/>
                                <DataGridTextColumn Header="Время входа" Binding="{Binding EntryTime, StringFormat=HH:mm:ss}" Width="120"/>
                                <DataGridTextColumn Header="Цель" Binding="{Binding Purpose}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Margin="20,0,20,20">
            <DataGrid x:Name="requestsGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" RowHeight="45" AlternatingRowBackground="#F8F9FA" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding request_id}" Width="60"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding request_type}" Width="80"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding full_name}" Width="150"/>
                    <DataGridTextColumn Header="Подразделение" Binding="{Binding department_name}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding visitor_email}" Width="180"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding phone}" Width="120"/>
                    <DataGridTextColumn Header="Дата начала" Binding="{Binding start_date, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Дата окончания" Binding="{Binding end_date, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="100"/>
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Просмотр" Click="ViewRequest_Click" Tag="{Binding}" Style="{StaticResource ActionButton}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Нижняя панель -->
        <Border Grid.Row="3" Background="#1E3A5F">
            <TextBlock Text="© 2024 ХранительПРО" Foreground="#7F8C8D" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>