<Window x:Class="HranitelPRO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8"
        Icon="C:\Shumailov\Практика\4 день\PassOfficeApp\HranitelPRO\images\icon.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E3A5F">
            <StackPanel Orientation="Horizontal" Margin="10">
                <Image Source="Images/icon.png" Width="32" Height="32" Margin="0,0,10,0"/>
                <TextBlock Text="ХранительПРО" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel x:Name="userPanel" Orientation="Horizontal" Margin="20,0,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="userEmailText" Foreground="White" VerticalAlignment="Center"/>
                    <Button x:Name="logoutButton" Content="Выйти" Click="LogoutButton_Click" Margin="10,0,0,0" Background="#C0392B" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" x:Name="mainContent">
            <!-- Форма авторизации посетителя -->
            <StackPanel x:Name="loginPanel" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Авторизация" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBox x:Name="loginEmail" Margin="0,0,0,10" Height="35"/>
                <PasswordBox x:Name="loginPassword" Margin="0,0,0,10" Height="35"/>
                <Button x:Name="loginButton" Content="Войти" Click="LoginButton_Click" Background="#27AE60" Foreground="White" Height="40" Margin="0,0,0,10"/>

                <TextBlock HorizontalAlignment="Center" Margin="0,10">
                    <Hyperlink x:Name="registerLink" Click="RegisterLink_Click">Зарегистрироваться</Hyperlink>
                </TextBlock>

                <Separator Margin="0,15" Height="1" Background="#D0D5DD"/>

                <Button x:Name="employeeLoginButton" Content="Вход для сотрудников" Click="EmployeeLoginButton_Click" 
                        Background="#3498DB" Foreground="White" Height="40" Margin="0,10,0,0"/>

                <TextBlock x:Name="loginErrorText" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Форма регистрации -->
            <StackPanel x:Name="registerPanel" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBox x:Name="regEmail" Margin="0,0,0,10" Height="35"/>
                <PasswordBox x:Name="regPassword" Margin="0,0,0,5" Height="35"/>
                <TextBlock Text="8+ символов, Aa, 1, @" FontSize="10" Foreground="Gray" Margin="0,0,0,10"/>
                <PasswordBox x:Name="regConfirmPassword" Margin="0,0,0,10" Height="35"/>
                <Button x:Name="registerButton" Content="Зарегистрироваться" Click="RegisterButton_Click" Background="#27AE60" Foreground="White" Height="40" Margin="0,0,0,10"/>

                <TextBlock HorizontalAlignment="Center" Margin="0,10">
                    <Hyperlink x:Name="backToLoginLink" Click="BackToLoginLink_Click">Войти</Hyperlink>
                </TextBlock>

                <TextBlock x:Name="registerErrorText" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Основное приложение -->
            <Grid x:Name="appPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1E3A5F">
                    <StackPanel Margin="10">
                        <Button x:Name="personalButton" Content="Личная заявка" Click="PersonalButton_Click" Height="40" Margin="0,5" Background="#3498DB" Foreground="White"/>
                        <Button x:Name="groupButton" Content="Групповая заявка" Click="GroupButton_Click" Height="40" Margin="0,5" Background="#27AE60" Foreground="White"/>
                        <Button x:Name="myRequestsButton" Content="Мои заявки" Click="MyRequestsButton_Click" Height="40" Margin="0,5" Background="#F39C12" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Frame x:Name="contentFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#1E3A5F">
            <TextBlock Text="© 2024 ХранительПРО" Foreground="#7F8C8D" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>