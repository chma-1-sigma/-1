<Window x:Class="HranitelPRO.RequestDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали заявки" Height="600" Width="750"
        WindowStartupLocation="CenterOwner" Background="#F0F4F8">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Информация о заявке" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Border Background="#F0F4F8" CornerRadius="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="№ заявки:" Grid.Row="0" Grid.Column="0" FontWeight="Bold" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtRequestId" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="Тип:" Grid.Row="0" Grid.Column="2" FontWeight="Bold" Margin="20,0,20,0"/>
                        <TextBlock x:Name="txtRequestType" Grid.Row="0" Grid.Column="3"/>

                        <TextBlock Text="Дата посещения:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtVisitDate" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="Статус:" Grid.Row="1" Grid.Column="2" FontWeight="Bold" Margin="20,0,20,0"/>
                        <TextBlock x:Name="txtStatus" Grid.Row="1" Grid.Column="3"/>

                        <TextBlock Text="Цель:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtPurpose" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="Посетители" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListBox x:Name="visitorsListBox" Height="250">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,2" Background="#F8F9FA" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" MouseRightButtonUp="Visitor_MouseRightButtonUp" Tag="{Binding}">
                                        <Run Text="{Binding FullName}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="Gray">
                                        <Run Text="Паспорт: "/>
                                        <Run Text="{Binding PassportSeries}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding PassportNumber}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11">
                                        <Run Text="Прибытие: "/>
                                        <Run Text="{Binding ArrivalTime, StringFormat=HH:mm}"/>
                                        <Run Text=" Убытие: "/>
                                        <Run Text="{Binding DepartureTime, StringFormat=HH:mm}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnConfirmArrival" Content="Подтвердить прибытие" Click="ConfirmArrival_Click" Background="#27AE60" Foreground="White" Height="40" Width="150" Margin="0,0,10,0"/>
            <Button x:Name="btnConfirmDeparture" Content="Подтвердить убытие" Click="ConfirmDeparture_Click" Background="#F39C12" Foreground="White" Height="40" Width="150" Margin="0,0,10,0"/>
            <Button x:Name="btnClose" Content="Закрыть" Click="Close_Click" Background="#95A5A6" Foreground="White" Height="40" Width="100"/>
        </StackPanel>
    </Grid>
</Window>