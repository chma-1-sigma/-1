<Window x:Class="HranitelPro.Admin.RequestReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр заявки" Height="600" Width="700"
        WindowStartupLocation="CenterOwner" Background="#F0F4F8">

    <ScrollViewer>
        <Border Background="White" CornerRadius="12" Margin="10" Padding="20">
            <StackPanel>
                <TextBlock Text="Просмотр заявки" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Background="#F0F4F8" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="№:" Grid.Row="0" Grid.Column="0" FontWeight="Bold" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtId" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="Тип:" Grid.Row="0" Grid.Column="2" FontWeight="Bold" Margin="20,0,20,0"/>
                        <TextBlock x:Name="txtType" Grid.Row="0" Grid.Column="3"/>
                        <TextBlock Text="Статус:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtStatus" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="Дата:" Grid.Row="1" Grid.Column="2" FontWeight="Bold" Margin="20,0,20,0"/>
                        <TextBlock x:Name="txtDate" Grid.Row="1" Grid.Column="3"/>
                    </Grid>
                </Border>

                <Border Background="#F0F4F8" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Информация о посетителе" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="ФИО:" FontWeight="Bold"/>
                                <TextBlock x:Name="txtFullName" Margin="0,5,0,15"/>
                                <TextBlock Text="Email:" FontWeight="Bold"/>
                                <TextBlock x:Name="txtEmail" Margin="0,5,0,15"/>
                                <TextBlock Text="Телефон:" FontWeight="Bold"/>
                                <TextBlock x:Name="txtPhone" Margin="0,5,0,15"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Паспорт:" FontWeight="Bold"/>
                                <TextBlock x:Name="txtPassport" Margin="0,5,0,15"/>
                                <TextBlock Text="Организация:" FontWeight="Bold"/>
                                <TextBlock x:Name="txtOrg" Margin="0,5,0,15"/>
                                <TextBlock Text="Дата рождения:" FontWeight="Bold"/>
                                <TextBlock x:Name="txtBirthDate" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#F0F4F8" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Дата и время посещения" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Дата:" Grid.Column="0" FontWeight="Bold" Margin="0,0,20,0"/>
                            <DatePicker x:Name="dpVisitDate" Grid.Column="1" Width="150" Height="35"/>
                            <TextBlock Text="Время:" Grid.Column="2" FontWeight="Bold" Margin="20,0,20,0"/>
                            <TextBox x:Name="txtVisitTime" Grid.Column="3" Width="100" Height="35" Text="10:00"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#F0F4F8" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Причина отказа" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox x:Name="txtRejectionReason" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                                 BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,5" IsEnabled="False"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <Button x:Name="btnApprove" Content="Одобрить" Click="Approve_Click" 
                            Background="#27AE60" Foreground="White" Height="40" Width="120" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button x:Name="btnReject" Content="Отклонить" Click="Reject_Click" 
                            Background="#E74C3C" Foreground="White" Height="40" Width="120" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button x:Name="btnClose" Content="Закрыть" Click="Close_Click" 
                            Background="#95A5A6" Foreground="White" Height="40" Width="120" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>