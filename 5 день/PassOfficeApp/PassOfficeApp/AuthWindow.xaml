<Window x:Class="PassOfficeApp.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация сотрудника" Height="400" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="16" Margin="20">
        <StackPanel Margin="30" VerticalAlignment="Center">
            <TextBlock Text="Терминал сотрудника" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Введите код авторизации" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <PasswordBox x:Name="authCodeBox" Height="45" FontSize="16" HorizontalContentAlignment="Center" Margin="0,0,0,20" BorderBrush="#D0D5DD" BorderThickness="1" Padding="10,0"/>
            <Button x:Name="loginButton" Content="Войти" Click="LoginButton_Click" Background="#27AE60" Foreground="White" Height="45" FontSize="16" Cursor="Hand"/>
            <TextBlock x:Name="errorText" Foreground="#E74C3C" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="12"/>
        </StackPanel>
    </Border>
</Window>